<UserControl x:Class="PersonalFinanceTracker.Views.TransactionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PersonalFinanceTracker.Models">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,24">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButton}"
                    Content="📥  Export CSV"
                    VerticalAlignment="Center"
                    Command="{Binding ExportCsvCommand}"/>
            <StackPanel>
                <TextBlock Text="Transactions" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Manage income and expenses" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Add transaction form -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="New transaction" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Description" Margin="0,0,8,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldLabel}" Text="{Binding AmountLabel}" Margin="4,0,4,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="Type" Margin="4,0,4,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Category" Margin="4,0,4,6"/>

                    <!-- Inputs -->
                    <TextBox  Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                              Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox  Grid.Row="1" Grid.Column="1" Margin="4,0"
                              Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    <ComboBox Grid.Row="1" Grid.Column="2" Margin="4,0"
                              ItemsSource="{Binding TransactionTypes}"
                              SelectedItem="{Binding NewType}"/>
                    <ComboBox Grid.Row="1" Grid.Column="3" Margin="4,0"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding NewCategory}"
                              DisplayMemberPath="Name"/>
                    <Button   Grid.Row="1" Grid.Column="4" Margin="8,0,0,0"
                              ToolTip="Suggest category from description (AI)"
                              Command="{Binding SuggestCategoryCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="#7E57C2"/>
                                <Setter Property="Content"    Value="✨ AI"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuggesting}" Value="True">
                                        <Setter Property="Content"   Value="..."/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button   Grid.Row="1" Grid.Column="5" Margin="8,0,0,0"
                              Style="{StaticResource PrimaryButton}"
                              Content="+ Add"
                              Command="{Binding AddTransactionCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Transactions list -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Width="110"
                                        Binding="{Binding Date, StringFormat=yyyy.MM.dd}"/>
                    <DataGridTextColumn Header="Description" Width="*"
                                        Binding="{Binding Description}"/>
                    <DataGridTemplateColumn Header="Category" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Category.Icon}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Category.Name}"/>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Type" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:TransactionType.Income}">
                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                    <Setter Property="Text" Value="Income"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:TransactionType.Expense}">
                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                    <Setter Property="Text" Value="Expense"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Amount" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FormattedAmount}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:TransactionType.Income}">
                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:TransactionType.Expense}">
                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource DangerButton}" Content="🗑" FontSize="12"
                                        Command="{Binding DataContext.DeleteTransactionCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
