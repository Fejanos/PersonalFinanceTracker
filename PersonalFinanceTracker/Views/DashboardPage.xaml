<UserControl x:Class="PersonalFinanceTracker.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel>

            <!-- Header -->
            <DockPanel Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Pénzügyi áttekintő" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <ComboBox DockPanel.Dock="Right" VerticalAlignment="Center"
                          Width="160" HorizontalAlignment="Right"
                          ItemsSource="{Binding Periods}"
                          SelectedItem="{Binding SelectedPeriod}"/>
            </DockPanel>

            <!-- Summary cards -->
            <UniformGrid Columns="3" Margin="0,0,0,24">

                <!-- Balance -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Egyenleg" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource PrimaryBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} Ft">
                                    <Binding Path="Balance"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="💳 Jelenlegi egyenleg" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Income -->
                <Border Style="{StaticResource CardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="Összes bevétel" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource IncomeBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} Ft">
                                    <Binding Path="TotalIncome"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="📈 Bevételek összege" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Expense -->
                <Border Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Összes kiadás" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource ExpenseBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N0} Ft">
                                    <Binding Path="TotalExpense"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="📉 Kiadások összege" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Placeholder for charts (LiveCharts will be added in next commit) -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel HorizontalAlignment="Center" Margin="0,40">
                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Grafikonok hamarosan..." FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
