<UserControl x:Class="PersonalFinanceTracker.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
        <StackPanel>

            <!-- Header -->
            <DockPanel Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Financial overview" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <ComboBox DockPanel.Dock="Right" VerticalAlignment="Center"
                          Width="160" HorizontalAlignment="Right"
                          ItemsSource="{Binding Periods}"
                          SelectedItem="{Binding SelectedPeriod}"/>
            </DockPanel>

            <!-- Summary cards -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Balance" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Text="{Binding BalanceFormatted}"/>
                        <TextBlock Text="💳 Current balance" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="Total Income" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource IncomeBrush}"
                                   Text="{Binding TotalIncomeFormatted}"/>
                        <TextBlock Text="📈 Sum of income" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Total Expense" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,8,0,0"
                                   Foreground="{StaticResource ExpenseBrush}"
                                   Text="{Binding TotalExpenseFormatted}"/>
                        <TextBlock Text="📉 Sum of expenses" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Pie: expenses by category -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Expenses by Category" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <lvc:PieChart Height="280"
                                      Series="{Binding ExpenseByCategory}"
                                      LegendPosition="Right"/>
                    </StackPanel>
                </Border>

                <!-- Bar: monthly income vs expense -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Monthly Income vs Expense" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <lvc:CartesianChart Height="280"
                                            Series="{Binding MonthlySeries}"
                                            XAxes="{Binding MonthlyXAxes}"
                                            YAxes="{Binding MonthlyYAxes}"
                                            LegendPosition="Top"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
