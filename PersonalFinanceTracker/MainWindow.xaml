<Window x:Class="PersonalFinanceTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PersonalFinanceTracker.ViewModels"
        xmlns:views="clr-namespace:PersonalFinanceTracker.Views"
        Title="Personal Finance Tracker" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- DataTemplates: which View belongs to which ViewModel -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
            <views:CategoriesPage/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,20">
                    <TextBlock Text="💰" FontSize="32" HorizontalAlignment="Center"/>
                    <TextBlock Text="Finance Tracker" Foreground="White"
                               FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <TextBlock>
                            <Run Text="📊  "/>
                            <Run Text="Dashboard"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Transactions">
                        <TextBlock>
                            <Run Text="💸  "/>
                            <Run Text="Tranzakciók"/>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Categories">
                        <TextBlock>
                            <Run Text="🏷️  "/>
                            <Run Text="Kategóriák"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Margin="0"/>
    </Grid>
</Window>
