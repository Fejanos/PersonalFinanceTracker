<Window x:Class="PersonalFinanceTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PersonalFinanceTracker.ViewModels"
        xmlns:views="clr-namespace:PersonalFinanceTracker.Views"
        Title="Personal Finance Tracker" Height="760" Width="1240"
        MinHeight="640" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
            <views:CategoriesPage/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,20">
                    <Border Width="56" Height="56" CornerRadius="14"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="$" Foreground="White"
                                   FontSize="32" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Finance Tracker" Foreground="White"
                               FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                            Content="📊   Dashboard"/>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Transactions"
                            Content="💸   Transactions"/>
                    <Button Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Categories"
                            Content="🏷️   Categories"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main area: top bar + content -->
        <DockPanel Grid.Column="1">
            <!-- Top bar -->
            <Border DockPanel.Dock="Top" Background="White" Height="64"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <DockPanel Margin="30,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Currency:" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" Margin="0,0,10,0"/>
                        <ComboBox Width="140" VerticalAlignment="Center"
                                  ItemsSource="{Binding Currency.AvailableCurrencies}"
                                  SelectedItem="{Binding Currency.CurrentCurrency}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveMenu}"
                               VerticalAlignment="Center"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </DockPanel>
            </Border>

            <!-- Page content -->
            <ContentControl Content="{Binding CurrentPage}"/>
        </DockPanel>
    </Grid>
</Window>
