<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BackgroundColor">#F5F7FA</Color>
    <Color x:Key="SidebarColor">#1E2235</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="SidebarActiveColor">#2D3450</Color>

    <!-- Accent -->
    <Color x:Key="PrimaryColor">#5C6BC0</Color>
    <Color x:Key="IncomeColor">#4CAF50</Color>
    <Color x:Key="ExpenseColor">#F44336</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="TextLightColor">#FFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"         Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="CardBrush"            Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"   Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="IncomeBrush"          Color="{StaticResource IncomeColor}"/>
    <SolidColorBrush x:Key="ExpenseBrush"         Color="{StaticResource ExpenseColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextLightBrush"       Color="{StaticResource TextLightColor}"/>

</ResourceDictionary>
